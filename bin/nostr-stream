#!/usr/bin/env perl

use strictures 2;

$| = 1;
binmode(STDOUT, ':encoding(UTF-8)');
binmode(STDERR, ':encoding(UTF-8)');

use Net::Nostr::Client;
use Net::Nostr::Filter;
use POSIX qw(strftime);
use AnyEvent;

my $relay = shift // 'wss://nos.lol';

my $client = Net::Nostr::Client->new;

$client->on(event => sub {
    my ($sub_id, $event) = @_;
    my $pk   = substr($event->pubkey, 0, 8);
    my $time = strftime('%H:%M:%S', localtime($event->created_at));
    my $text = $event->content;
    $text =~ s/\n/ /g;
    print "[$time] $pk: $text\n";
});

$client->on(eose => sub {
    print "--- live ---\n";
});

$client->on(notice => sub {
    my ($msg) = @_;
    warn "NOTICE: $msg\n";
});

$client->on(closed => sub {
    my ($sub_id, $msg) = @_;
    warn "CLOSED: [$sub_id] $msg\n";
});

print "Connecting to $relay ...\n";
$client->connect($relay);
print "Connected. Streaming kind 1 notes (Ctrl-C to stop)\n\n";

my $filter = Net::Nostr::Filter->new(kinds => [1], since => time() - 300);
$client->subscribe('stream', $filter);

AnyEvent->condvar->recv;
